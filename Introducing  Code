### 1. Setup and Data Loading
```python
import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import OneHotEncoder, LabelEncoder
from sklearn.compose import ColumnTransformer
from sklearn.pipeline import Pipeline
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import accuracy_score, classification_report

df = pd.read_csv('/loan_data (2).csv')
print(df.head())
```

### 2. Data Preprocessing
```python
features = ['previous_loan_defaults_on_file', 'loan_int_rate', 'loan_intent', 'person_income','loan_percent_income']
target = 'loan_status'

df_clean = df[features + [target]].dropna()
X = df_clean[features]
y = df_clean[target]

label_encoder = LabelEncoder()
y_encoded = label_encoder.fit_transform(y)

X_train, X_test, y_train, y_test = train_test_split(X, y_encoded, test_size=0.25, random_state=42, stratify=y_encoded)
```

### 3. Model Pipeline Construction
```python
preprocessor = ColumnTransformer(
    transformers=[
        ('cat', OneHotEncoder(handle_unknown='ignore'), features)
    ])

model = RandomForestClassifier(n_estimators=100, random_state=42, class_weight='balanced')

pipeline = Pipeline(steps=[('preprocessor', preprocessor),
                           ('classifier', model)])
```

### 4. Training and Evaluation
```python
pipeline.fit(X_train, y_train)

y_pred = pipeline.predict(X_test)
accuracy = accuracy_score(y_test, y_pred)
print(f'Model Accuracy: {accuracy:.4f}')
print(classification_report(y_test, y_pred, target_names=[str(c) for c in label_encoder.classes_]))
```

### 5. Custom Prediction
```python
new_loan_data = pd.DataFrame({
    'previous_loan_defaults_on_file': ['Yes'],
    'loan_int_rate': [0.15],
    'loan_intent': ['MEDICAL'],
    'person_income': [10000.0],
    'loan_percent_income': [0.20]
})

status = pipeline.predict(new_loan_data)[0]

if status == 0:
    print(f'Predicted Status: {status} - This person is not a loan defaulter.')
else:
    print(f'Predicted Status: {status} - This person is likely to be a loan defaulter.')

print(f'Model Accuracy: {accuracy:.4f}')
```
